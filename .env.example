# ── Agent model routing (src/agent/model-router.ts) ───────────────────────
# ALL roles → z.ai direct (avoids OpenRouter markup). Same endpoint + key.
#   REASONING/EXTRACTION/CHEAP → glm-5.2
#   VISION                     → glm-5v-turbo (multimodal)
# Override per-role with MAVERICK_<ROLE>_MODEL (e.g. MAVERICK_VISION_MODEL=glm-4.6v).
# Escape hatch: any MAVERICK_<ROLE>_MODEL=claude-* routes that role to Anthropic.
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_API_KEY=
ZAI_MODEL=glm-5.2
ZAI_VISION_MODEL=glm-5v-turbo
# Optional: route agent z.ai calls through a proxy/gateway instead of z.ai direct.
# MAVERICK_OPENAI_BASE_URL=

# Route HCP writes through the housecall-pro-mcp daemon instead of the built-in
# cookie client. Default off. When true, the daemon must be running and these set:
HCP_VIA_MCP=false
HCP_MCP_URL=http://127.0.0.1:7332/
HCP_MCP_TOKEN=

# Customer SMS chatbot
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=       # E.164 format, e.g. +14695551234
CUSTOMER_CHAT_PORT=3012
PUBLIC_URL=                # Set to ngrok/tunnel URL in local dev; https://chat.grizzlyelectrical.net in prod

# Employee SMS chatbot (same server, same port, different number)
EMPLOYEE_PHONE_NUMBER=     # E.164 format — internal employee number
